-- 5. Rank Products by Monthly Sales Quantity Partitioned by Fiscal Year
-- Window function ranking products by total quantity per fiscal year
SELECT 
    YEAR(DATEADD(month, 4, date)) AS fiscal_year,
    product_code,
    SUM(sold_quantity) AS total_sold_qty,
    DENSE_RANK() OVER (
        PARTITION BY YEAR(DATEADD(month, 4, date)) 
        ORDER BY SUM(sold_quantity) DESC
    ) AS product_rank
FROM fact_sales_monthly
GROUP BY YEAR(DATEADD(month, 4, date)), product_code;



