    p.product_code,
    p.product,
    p.variant,
    ROUND(AVG(g.gross_price), 2) AS avg_gross_price
FROM fact_gross_price g
JOIN dim_product p ON g.product_code = p.product_code
GROUP BY p.product_code, p.product, p.variant
ORDER BY avg_gross_price DESC;


-- Task 6: Forecast Accuracy Analysis

-- SQL Query with Pivot Table & Accuracy %
-- Forecast Accuracy Calculation Query using Pivot Table Logic
WITH MonthlyAgg AS (
    SELECT 
        s.product_code,
        YEAR(DATEADD(month, 4, s.date)) AS fiscal_year,
        MONTH(s.date) AS month_num,
        SUM(s.sold_quantity) AS actual_qty,
        SUM(f.forecast_quantity) AS forecast_qty
    FROM fact_sales_monthly s
    FULL OUTER JOIN fact_forecast_monthly f 
        ON s.product_code = f.product_code 
        AND s.customer_code = f.customer_code 
        AND s.date = f.date
    WHERE s.product_code = 'A0118150101' -- Target product
    GROUP BY s.product_code, YEAR(DATEADD(month, 4, s.date)), MONTH(s.date)
)
SELECT 
    fiscal_year,
    -- Pivoted Sold vs Forecast side by side for Sep (Month 9) and Oct (Month 10)
    ISNULL(SUM(CASE WHEN month_num = 9 THEN forecast_qty END), 0) AS sep_forecast,
    ISNULL(SUM(CASE WHEN month_num = 9 THEN actual_qty END), 0) AS sep_actual,
    ROUND(
        ISNULL(SUM(CASE WHEN month_num = 9 THEN actual_qty END), 0) * 100.0 / 
        NULLIF(SUM(CASE WHEN month_num = 9 THEN forecast_qty END), 0), 2
    ) AS sep_accuracy_pct
FROM MonthlyAgg
GROUP BY fiscal_year;


