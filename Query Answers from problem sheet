-- Monthly Gross Sales Report Query
SELECT 
    s.date,
    s.product_code,
    p.product AS product_name,
    p.variant,
    s.sold_quantity,
    g.gross_price,
    ROUND(s.sold_quantity * g.gross_price, 2) AS gross_price_total -- Gross Sales calculation
FROM fact_sales_monthly s
