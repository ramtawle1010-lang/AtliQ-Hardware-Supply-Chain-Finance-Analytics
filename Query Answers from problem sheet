GO

-- 19. Trigger: Outlier Detection on Monthly Sales
-- Audit table for sales anomalies
CREATE TABLE sales_outliers (
    date DATE,
    product_code VARCHAR(45),
    customer_code INT,
    sold_quantity INT,
    flagged_reason VARCHAR(255)
);
GO

-- Trigger flagging transactions exceeding 3x the average sold quantity
CREATE TRIGGER trg_flag_sales_outliers
ON fact_sales_monthly
AFTER INSERT
AS
BEGIN
    DECLARE @avg_qty FLOAT;
    SELECT @avg_qty = AVG(sold_quantity) FROM fact_sales_monthly;

    INSERT INTO sales_outliers (date, product_code, customer_code, sold_quantity, flagged_reason)
    SELECT date, product_code, customer_code, sold_quantity, 'Quantity > 3x average'
    FROM inserted
    WHERE sold_quantity > (@avg_qty * 3);
END;
GO

