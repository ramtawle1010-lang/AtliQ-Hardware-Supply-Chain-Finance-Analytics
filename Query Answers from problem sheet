-- 7. Function: Multi-Year Total Manufacturing Cost

-- Function to calculate total manufacturing cost across a range of years
CREATE FUNCTION dbo.get_total_mfg_cost (
    @p_code VARCHAR(45),
    @start_year INT,
    @end_year INT
)
RETURNS DECIMAL(15,4)
AS
BEGIN
    DECLARE @total_cost DECIMAL(15,4);
    
    SELECT @total_cost = SUM(manufacturing_cost)
    FROM (
        SELECT manufacturing_cost 
        FROM fact_manufacturing_cost
        WHERE product_code = @p_code 
          AND cost_year BETWEEN @start_year AND @end_year
    ) AS sub;
    
    RETURN ISNULL(@total_cost, 0);
END;
GO

-- 8. Inventory Enforced Insertion Procedure & Trigger

-- Assuming an inventory table exists
CREATE TABLE dim_inventory (
    product_code VARCHAR(45) PRIMARY KEY,
    available_qty INT
);
GO

-- Trigger preventing sales insertions if sold_quantity exceeds available inventory
CREATE TRIGGER trg_check_inventory
ON fact_sales_monthly
INSTEAD OF INSERT
AS
BEGIN
    IF EXISTS (
        SELECT 1 
        FROM inserted i
        JOIN dim_inventory inv ON i.product_code = inv.product_code
        WHERE i.sold_quantity > inv.available_qty
    )
    BEGIN
        RAISERROR ('Sold quantity exceeds available inventory!', 16, 1);
        ROLLBACK TRANSACTION;
    END
    ELSE
    BEGIN
        INSERT INTO fact_sales_monthly (date, product_code, customer_code, sold_quantity)
        SELECT date, product_code, customer_code, sold_quantity FROM inserted;
    END
END;
GO

-- 9. Month-over-Month Comparison using LAG

-- Compare monthly product sales with previous month's volume
SELECT 
    product_code,
    date,
    sold_quantity AS current_month_qty,
    LAG(sold_quantity, 1, 0) OVER (
        PARTITION BY product_code 
        ORDER BY date
    ) AS previous_month_qty,
    (sold_quantity - LAG(sold_quantity, 1, 0) OVER (
        PARTITION BY product_code ORDER BY date
    )) AS MoM_change
FROM fact_sales_monthly;

-- 10. Top-Selling Products per Market

-- Top product by sales quantity per market using CTE & window functions
WITH MarketSales AS (
    SELECT 
        c.market,
        s.product_code,
        SUM(s.sold_quantity) AS total_qty,
        DENSE_RANK() OVER (
            PARTITION BY c.market 
            ORDER BY SUM(s.sold_quantity) DESC
        ) AS rnk
    FROM fact_sales_monthly s
    JOIN dim_customer c ON s.customer_code = c.customer_code
    GROUP BY c.market, s.product_code
)
SELECT market, product_code, total_qty
FROM MarketSales
WHERE rnk = 1;

-- 11. Freight Cost Function & Update Procedure

-- Function to retrieve freight cost percentage for market & fiscal year
CREATE FUNCTION dbo.get_freight_pct (
    @market VARCHAR(45),
    @f_year INT
)
RETURNS DECIMAL(5,4)
AS
BEGIN
    DECLARE @pct DECIMAL(5,4);
    SELECT @pct = freight_pct FROM fact_freight_cost WHERE market = @market AND fiscal_year = @f_year;
    RETURN ISNULL(@pct, 0);
END;
GO

-- 12. Trigger: Automatic Inventory Reduction on Sale
-- Trigger to deduct sold quantity from inventory upon insertion
CREATE TRIGGER trg_update_inventory_on_sale
ON fact_sales_monthly
AFTER INSERT
AS
BEGIN
    UPDATE inv
    SET inv.available_qty = inv.available_qty - i.sold_quantity
    FROM dim_inventory inv
    JOIN inserted i ON inv.product_code = i.product_code;
END;
GO

-- 13. Referential Integrity Check Trigger
-- Trigger validating product presence in dim_product before insertion
CREATE TRIGGER trg_enforce_product_fk
ON fact_sales_monthly
AFTER INSERT
AS
BEGIN
    IF EXISTS (
        SELECT 1 FROM inserted i
        WHERE i.product_code NOT IN (SELECT product_code FROM dim_product)
    )
    BEGIN
        RAISERROR ('Invalid Product Code inserted.', 16, 1);
        ROLLBACK TRANSACTION;
    END
END;
GO

-- 14. Stored Procedure: Month-over-Month Growth Rate
-- Procedure generating MoM % growth report for a product
CREATE PROCEDURE sp_product_mom_growth
    @p_code VARCHAR(45)
AS
BEGIN
    WITH MonthlySales AS (
        SELECT 
            date,
            SUM(sold_quantity) AS current_qty,
            LAG(SUM(sold_quantity), 1) OVER (ORDER BY date) AS prev_qty
        FROM fact_sales_monthly
        WHERE product_code = @p_code
        GROUP BY date
    )
    SELECT 
        date,
        current_qty,
        prev_qty,
        ROUND(CAST((current_qty - prev_qty) AS FLOAT) / NULLIF(prev_qty, 0) * 100, 2) AS mom_growth_pct
    FROM MonthlySales;
END;
GO

-- 15. Function: Average Discount Percentage
-- Function returning average discount percentage granted for a product
CREATE FUNCTION dbo.get_avg_discount (@p_code VARCHAR(45))
RETURNS DECIMAL(5,4)
AS
BEGIN
    DECLARE @avg_disc DECIMAL(5,4);
    SELECT @avg_disc = AVG(discounts_pct) 
    FROM fact_post_invoice_deductions 
    WHERE product_code = @p_code;
    
    RETURN ISNULL(@avg_disc, 0);
END;
GO

-- 16.Top Purchaser in Each Region
-- Customer with highest total purchase quantity per region
WITH RegionPurchases AS (
    SELECT 
        c.region,
        c.customer_code,
        c.customer,
        SUM(s.sold_quantity) AS total_purchased,
        DENSE_RANK() OVER (
            PARTITION BY c.region 
            ORDER BY SUM(s.sold_quantity) DESC
        ) AS rnk
    FROM fact_sales_monthly s
    JOIN dim_customer c ON s.customer_code = c.customer_code
    GROUP BY c.region, c.customer_code, c.customer
)
SELECT region, customer_code, customer, total_purchased
FROM RegionPurchases
WHERE rnk = 1;

--17. Stored Procedure: Total Revenue for Period
-- Procedure calculating total gross revenue between start and end dates
CREATE PROCEDURE sp_get_total_period_revenue
    @start_date DATE,
    @end_date DATE
AS
BEGIN
    SELECT 
        SUM(s.sold_quantity * g.gross_price) AS total_gross_revenue
    FROM fact_sales_monthly s
    JOIN fact_gross_price g 
        ON s.product_code = g.product_code
        AND YEAR(DATEADD(month, 4, s.date)) = g.fiscal_year
    WHERE s.date BETWEEN @start_date AND @end_date;
END;
GO

-- 18. Trigger: Auto-Update Forecast on Product Addition
-- Trigger adding default forecast entry when a new product is added to catalog
