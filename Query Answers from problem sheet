--1. Function: Total Forecasted Quantity

-- Function to return total forecast quantity for a given product and fiscal year
CREATE FUNCTION dbo.get_total_forecast (
    @p_code VARCHAR(45),
    @f_year INT
)
RETURNS INT
AS
BEGIN
    DECLARE @total_qty INT;
    SELECT @total_qty = SUM(forecast_quantity)
    FROM fact_forecast_monthly
    WHERE product_code = @p_code AND fiscal_year = @f_year;
    
    RETURN ISNULL(@total_qty, 0);
END;
GO

-- 2. Customers Exceeding Average Monthly Sales Quantity

-- Query to find customers whose total purchased quantity exceeds average monthly sales quantity across all products
SELECT 
    customer_code, 
    SUM(sold_quantity) AS total_customer_sales
FROM fact_sales_monthly
GROUP BY customer_code
HAVING SUM(sold_quantity) > (
    SELECT AVG(monthly_total)
    FROM (
        SELECT SUM(sold_quantity) AS monthly_total
        FROM fact_sales_monthly
        GROUP BY date
    ) AS monthly_avg
);

-- 3. Stored Procedure: Update Gross Price

-- Procedure to update gross price for a product in a specific fiscal year
CREATE PROCEDURE sp_update_gross_price
    @p_code VARCHAR(45),
    @f_year INT,
    @new_price DECIMAL(15,4)
AS
BEGIN
    UPDATE fact_gross_price
    SET gross_price = @new_price
    WHERE product_code = @p_code AND fiscal_year = @f_year;
END;
GO

